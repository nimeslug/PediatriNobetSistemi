@model PediatriNobetSistemi.Models.Entities.Bolum
@{
    ViewData["Title"] = "Bolum Duzenle";
}

<h1>Bolum Duzenle</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Ad" class="form-label"></label>
                <input asp-for="Ad" class="form-control" />
                <span asp-validation-for="Ad" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Aciklama" class="form-label"></label>
                <textarea asp-for="Aciklama" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Aciklama" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="HastaSayisi" class="form-label"></label>
                    <input asp-for="HastaSayisi" class="form-control" type="number" min="0" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="BosYatakSayisi" class="form-label"></label>
                    <input asp-for="BosYatakSayisi" class="form-control" type="number" min="0" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="ToplamYatakSayisi" class="form-label"></label>
                    <input asp-for="ToplamYatakSayisi" class="form-control" type="number" min="0" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="GorselUrl" class="form-label">Gorsel URL</label>
                <input asp-for="GorselUrl" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="SorumluOgretimUyesiId" class="form-label">Sorumlu Ogretim Uyesi</label>
                <select asp-for="SorumluOgretimUyesiId" asp-items="ViewBag.OgretimUyeleri" class="form-select">
                    <option value="">— Sorumlu yok —</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Guncelle</button>
            <a asp-action="Index" class="btn btn-secondary">Iptal</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
