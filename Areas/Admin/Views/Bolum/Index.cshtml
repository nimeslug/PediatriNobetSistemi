@model IEnumerable<PediatriNobetSistemi.Models.Entities.Bolum>
@{
    ViewData["Title"] = "Bolumler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Bolumler</h1>
    <a asp-action="Create" class="btn btn-success">+ Yeni Bolum Ekle</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Ad</th>
                    <th>Sorumlu Ogretim Uyesi</th>
                    <th class="text-center">Hasta</th>
                    <th class="text-center">Bos Yatak</th>
                    <th class="text-center">Toplam Yatak</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Ad</strong></td>
                        <td>
                            @if (item.SorumluOgretimUyesi != null)
                            {
                                @($"{item.SorumluOgretimUyesi.Unvan} {item.SorumluOgretimUyesi.Ad} {item.SorumluOgretimUyesi.Soyad}")
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">@item.HastaSayisi</td>
                        <td class="text-center">@item.BosYatakSayisi</td>
                        <td class="text-center">@item.ToplamYatakSayisi</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detay</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Duzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Henuz bolum eklenmemis.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
