@model PediatriNobetSistemi.Models.Entities.Nobet
@{
    ViewData["Title"] = "Nobet Detayi";
}

<h1>Nobet Detayi</h1>
<hr />

<dl class="row">
    <dt class="col-sm-3">Tarih</dt>
    <dd class="col-sm-9">@Model.Tarih.ToString("dd.MM.yyyy dddd")</dd>

    <dt class="col-sm-3">Saatler</dt>
    <dd class="col-sm-9">@Model.BaslangicSaati.ToString(@"hh\:mm") - @Model.BitisSaati.ToString(@"hh\:mm")</dd>

    <dt class="col-sm-3">Asistan</dt>
    <dd class="col-sm-9">@Model.Asistan?.Ad @Model.Asistan?.Soyad</dd>

    <dt class="col-sm-3">Bolum</dt>
    <dd class="col-sm-9">@Model.Bolum?.Ad</dd>

    <dt class="col-sm-3">Notlar</dt>
    <dd class="col-sm-9">@(Model.Notlar ?? "—")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Duzenle</a>
<a asp-action="Index" class="btn btn-secondary">Listeye Don</a>
