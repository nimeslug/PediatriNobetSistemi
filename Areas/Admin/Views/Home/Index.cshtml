@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Yönetim Paneli</h2>
        <p class="text-muted mb-0">Pediatri Nöbet Sistemi yönetim merkezi</p>
    </div>
    <span class="badge bg-success p-2">Admin: @User.Identity?.Name</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-4">
        <a asp-area="Admin" asp-controller="Bolum" asp-action="Index" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 2rem; margin-right: 0.75rem;">🏥</span>
                        <h5 class="card-title mb-0">Bölümler</h5>
                    </div>
                    <p class="text-muted small mb-0">Pediatri bölümlerini ekle, düzenle, sil</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-area="Admin" asp-controller="Asistan" asp-action="Index" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 2rem; margin-right: 0.75rem;">👨‍⚕️</span>
                        <h5 class="card-title mb-0">Asistanlar</h5>
                    </div>
                    <p class="text-muted small mb-0">Asistan kadrosunu yönet</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-area="Admin" asp-controller="OgretimUyesi" asp-action="Index" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 2rem; margin-right: 0.75rem;">👩‍🏫</span>
                        <h5 class="card-title mb-0">Öğretim Üyeleri</h5>
                    </div>
                    <p class="text-muted small mb-0">Öğretim üyelerini yönet</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-area="Admin" asp-controller="Nobet" asp-action="Index" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 2rem; margin-right: 0.75rem;">📅</span>
                        <h5 class="card-title mb-0">Nöbetler</h5>
                    </div>
                    <p class="text-muted small mb-0">Nöbet programını oluştur ve düzenle</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-area="Admin" asp-controller="Musaitlik" asp-action="Index" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 2rem; margin-right: 0.75rem;">🕐</span>
                        <h5 class="card-title mb-0">Müsaitlikler</h5>
                    </div>
                    <p class="text-muted small mb-0">Öğretim üyesi müsaitlik slotları</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-area="Admin" asp-controller="Randevu" asp-action="Index" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 2rem; margin-right: 0.75rem;">📋</span>
                        <h5 class="card-title mb-0">Randevular</h5>
                    </div>
                    <p class="text-muted small mb-0">Tüm randevuları görüntüle ve yönet</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-4">
        <a asp-area="Admin" asp-controller="AcilDurum" asp-action="Index" class="text-decoration-none">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span style="font-size: 2rem; margin-right: 0.75rem;">🚨</span>
                        <h5 class="card-title mb-0">Acil Durumlar</h5>
                    </div>
                    <p class="text-muted small mb-0">Acil durum haberlerini yayınla, mail gönder</p>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="alert alert-info">
    <strong>💡 İpucu:</strong> Sol menüden istediğin modüle hızlıca geçebilirsin.
    Yeni acil durum haberi yayınladığında tüm asistan ve öğretim üyelerine otomatik mail gönderilir.
</div>