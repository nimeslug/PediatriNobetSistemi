<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .admin-body { background-color: #f8fafc; min-height: 100vh; }
        .admin-navbar { background-color: #1f2937; padding: 0.75rem 1rem; }
        .admin-navbar .navbar-brand { color: #fff; font-weight: 600; }
        .sidebar { min-height: calc(100vh - 60px); background-color: #1f2937; padding: 0; }
        .sidebar a {
            color: rgba(255,255,255,0.85);
            padding: 0.85rem 1.25rem;
            display: block;
            text-decoration: none;
            border-left: 3px solid transparent;
            font-size: 0.95rem;
            transition: all 0.15s;
        }
        .sidebar a:hover, .sidebar a.active {
            background-color: rgba(0,169,157,0.15);
            border-left-color: #00a99d;
            color: #4dc2b8;
        }
        .admin-content { padding: 2rem; }
    </style>
</head>
<body class="admin-body">
    <nav class="admin-navbar d-flex justify-content-between align-items-center">
        <a class="navbar-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">
            🩺 Pediatri Nöbet Sistemi - Yönetim
        </a>
        <div class="d-flex align-items-center">
            <span class="text-light me-3 small">@User.Identity?.Name</span>
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-light me-2">
                🏠 Siteye Dön
            </a>
            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                <button type="submit" class="btn btn-sm btn-danger">Çıkış Yap</button>
            </form>
        </div>
    </nav>

    <div class="container-fluid p-0">
        <div class="row g-0">
            <div class="col-md-2 sidebar">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index">📊 Dashboard</a>
                <a asp-area="Admin" asp-controller="Bolum" asp-action="Index">🏥 Bölümler</a>
                <a asp-area="Admin" asp-controller="Asistan" asp-action="Index">👨‍⚕️ Asistanlar</a>
                <a asp-area="Admin" asp-controller="OgretimUyesi" asp-action="Index">👩‍🏫 Öğretim Üyeleri</a>
                <a asp-area="Admin" asp-controller="Nobet" asp-action="Index">📅 Nöbetler</a>
                <a asp-area="Admin" asp-controller="Musaitlik" asp-action="Index">🕐 Müsaitlikler</a>
                <a asp-area="Admin" asp-controller="Randevu" asp-action="Index">📋 Randevular</a>
                <a asp-area="Admin" asp-controller="AcilDurum" asp-action="Index">🚨 Acil Durumlar</a>
                <hr class="text-light" />
                <a asp-area="" asp-controller="Home" asp-action="Index">🏠 Siteye Dön</a>
            </div>
            <main class="col-md-10 admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>