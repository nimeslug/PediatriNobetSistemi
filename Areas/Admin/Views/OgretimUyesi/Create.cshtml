@model PediatriNobetSistemi.Models.Entities.OgretimUyesi
@{
    ViewData["Title"] = "Yeni Ogretim Uyesi";
}

<h1>Yeni Ogretim Uyesi Ekle</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Unvan" class="form-label"></label>
                    <select asp-for="Unvan" class="form-select">
                        <option value="">— Sec —</option>
                        <option>Prof. Dr.</option>
                        <option>Doc. Dr.</option>
                        <option>Dr. Ogr. Uyesi</option>
                        <option>Ars. Gor. Dr.</option>
                    </select>
                    <span asp-validation-for="Unvan" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Ad" class="form-label"></label>
                    <input asp-for="Ad" class="form-control" />
                    <span asp-validation-for="Ad" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Soyad" class="form-label"></label>
                    <input asp-for="Soyad" class="form-control" />
                    <span asp-validation-for="Soyad" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Telefon" class="form-label"></label>
                    <input asp-for="Telefon" class="form-control" />
                    <span asp-validation-for="Telefon" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Adres" class="form-label"></label>
                <textarea asp-for="Adres" class="form-control" rows="2"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="UzmanlikAlani" class="form-label">Uzmanlik Alani</label>
                <input asp-for="UzmanlikAlani" class="form-control" placeholder="Cocuk Onkolojisi" />
            </div>

            <div class="mb-3">
                <label asp-for="BolumId" class="form-label">Bolum</label>
                <select asp-for="BolumId" asp-items="ViewBag.Bolumler" class="form-select">
                    <option value="">— Bolum sec —</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="FotoUrl" class="form-label">Foto URL</label>
                <input asp-for="FotoUrl" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Ozgecmis" class="form-label"></label>
                <textarea asp-for="Ozgecmis" class="form-control" rows="4"></textarea>
            </div>

            <button type="submit" class="btn btn-success">Kaydet</button>
            <a asp-action="Index" class="btn btn-secondary">Iptal</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
