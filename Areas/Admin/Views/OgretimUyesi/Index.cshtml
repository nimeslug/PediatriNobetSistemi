@model IEnumerable<PediatriNobetSistemi.Models.Entities.OgretimUyesi>
@{
    ViewData["Title"] = "Ogretim Uyeleri";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Ogretim Uyeleri</h1>
    <a asp-action="Create" class="btn btn-success">+ Yeni Ekle</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Unvan / Ad Soyad</th>
                    <th>Telefon</th>
                    <th>E-posta</th>
                    <th>Bolum</th>
                    <th>Uzmanlik</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Unvan @item.Ad @item.Soyad</strong></td>
                        <td>@item.Telefon</td>
                        <td>@item.Email</td>
                        <td>
                            @if (item.Bolum != null) { @item.Bolum.Ad }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>@(item.UzmanlikAlani ?? "—")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detay</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Duzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Henuz ogretim uyesi eklenmemis.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
