@model PediatriNobetSistemi.Models.Entities.AcilDurumHaberi
@{
    ViewData["Title"] = "Yeni Acil Durum";
}

<h1>Yeni Acil Durum Haberi</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Baslik" class="form-label"></label>
                <input asp-for="Baslik" class="form-control" />
                <span asp-validation-for="Baslik" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Icerik" class="form-label"></label>
                <textarea asp-for="Icerik" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Icerik" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Oncelik" class="form-label"></label>
                    <select asp-for="Oncelik" class="form-select">
                        <option value="0">Dusuk</option>
                        <option value="1">Orta</option>
                        <option value="2" selected>Yuksek</option>
                        <option value="3">Kritik</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BolumId" class="form-label">Bolum (opsiyonel)</label>
                    <select asp-for="BolumId" asp-items="ViewBag.Bolumler" class="form-select">
                        <option value="">— Tum bolumler —</option>
                    </select>
                </div>
            </div>

            <div class="card bg-light mb-3">
                <div class="card-body">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="gonderMail" name="gonderMail" value="true" checked />
                        <label class="form-check-label" for="gonderMail">
                            <strong>Mail Bildirimi Gonder</strong>
                            <small class="d-block text-muted">Tum asistan ve ogretim uyelerine bu haberi mail olarak gonder.</small>
                        </label>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-danger">Yayinla</button>
            <a asp-action="Index" class="btn btn-secondary">Iptal</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
