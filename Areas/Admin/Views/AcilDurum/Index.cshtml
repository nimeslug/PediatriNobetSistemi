@model IEnumerable<PediatriNobetSistemi.Models.Entities.AcilDurumHaberi>
@{
    ViewData["Title"] = "Acil Durum Haberleri";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Acil Durum Haberleri</h1>
    <a asp-action="Create" class="btn btn-danger">+ Yeni Acil Durum</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="alert alert-info small">
    <strong>Bilgi:</strong> Yeni acil durum eklerken "Mail gonder" secenegi aktifse, tum asistan ve ogretim uyelerine HTML formatinda mail gonderilir.
    Mail icin <code>appsettings.json</code> icindeki SMTP ayarlarinin dolu olmasi gerekir.
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Tarih</th>
                    <th>Baslik</th>
                    <th>Bolum</th>
                    <th>Oncelik</th>
                    <th>Mail</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.YayinTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                        <td><strong>@item.Baslik</strong></td>
                        <td>@(item.Bolum?.Ad ?? "—")</td>
                        <td>
                            @switch (item.Oncelik)
                            {
                                case PediatriNobetSistemi.Models.Entities.OncelikDuzeyi.Dusuk:
                                    <span class="badge bg-secondary">Dusuk</span>
                                    break;
                                case PediatriNobetSistemi.Models.Entities.OncelikDuzeyi.Orta:
                                    <span class="badge bg-info text-dark">Orta</span>
                                    break;
                                case PediatriNobetSistemi.Models.Entities.OncelikDuzeyi.Yuksek:
                                    <span class="badge bg-warning text-dark">Yuksek</span>
                                    break;
                                case PediatriNobetSistemi.Models.Entities.OncelikDuzeyi.Kritik:
                                    <span class="badge bg-danger">Kritik</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (item.MailGonderildi)
                            {
                                <span class="badge bg-success">Gonderildi</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Gonderilmedi</span>
                            }
                            <a asp-action="MailLoglari" asp-route-id="@item.Id" class="btn btn-sm btn-link p-0 ms-1">Loglar</a>
                        </td>
                        <td class="text-end">
                            <form asp-action="MailTekrarGonder" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-warning" title="Mail tekrar gonder">📧</button>
                            </form>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Duzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Henuz acil durum haberi yok.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
