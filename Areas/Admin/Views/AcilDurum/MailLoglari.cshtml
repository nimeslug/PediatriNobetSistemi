@model IEnumerable<PediatriNobetSistemi.Models.Entities.MailLog>
@{
    ViewData["Title"] = "Mail Gonderim Loglari";
}

<h1>Mail Gonderim Loglari</h1>
<p class="text-muted">Haber ID: @ViewBag.HaberId</p>
<hr />

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Tarih</th>
                    <th>Alici</th>
                    <th>Konu</th>
                    <th>Durum</th>
                    <th>Hata Mesaji</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.GonderimTarihi.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td>@log.AliciEmail</td>
                        <td><small>@log.Konu</small></td>
                        <td>
                            @if (log.Basarili)
                            {
                                <span class="badge bg-success">Basarili</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Basarisiz</span>
                            }
                        </td>
                        <td><small>@(log.HataMesaji ?? "—")</small></td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Bu haber icin mail logu yok.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Listeye Don</a>
