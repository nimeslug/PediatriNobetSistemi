@model IEnumerable<PediatriNobetSistemi.Models.Entities.Randevu>
@{
    ViewData["Title"] = "Randevular";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Randevular</h1>
    <a asp-action="Create" class="btn btn-success">+ Yeni Randevu</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="card card-body mb-3 bg-light">
    <div class="row align-items-end">
        <div class="col-md-4">
            <label class="form-label">Duruma Gore Filtrele</label>
            <select name="durum" class="form-select" onchange="this.form.submit()">
                <option value="">— Hepsi —</option>
                @foreach (var d in Enum.GetValues<PediatriNobetSistemi.Models.Entities.RandevuDurumu>())
                {
                    var secili = ViewBag.SecilenDurum != null && ((PediatriNobetSistemi.Models.Entities.RandevuDurumu)ViewBag.SecilenDurum) == d;
                    <option value="@d" selected="@secili">@d</option>
                }
            </select>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Tarih</th>
                    <th>Saatler</th>
                    <th>Asistan</th>
                    <th>Ogretim Uyesi</th>
                    <th>Konu</th>
                    <th>Durum</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Tarih.ToString("dd.MM.yyyy")</strong></td>
                        <td>@item.BaslangicSaati.ToString(@"hh\:mm") - @item.BitisSaati.ToString(@"hh\:mm")</td>
                        <td>@item.Asistan?.Ad @item.Asistan?.Soyad</td>
                        <td>@item.OgretimUyesi?.Unvan @item.OgretimUyesi?.Ad @item.OgretimUyesi?.Soyad</td>
                        <td><small>@(item.Konu ?? "—")</small></td>
                        <td>
                            @switch (item.Durum)
                            {
                                case PediatriNobetSistemi.Models.Entities.RandevuDurumu.Beklemede:
                                    <span class="badge bg-warning text-dark">Beklemede</span>
                                    break;
                                case PediatriNobetSistemi.Models.Entities.RandevuDurumu.Onaylandi:
                                    <span class="badge bg-success">Onaylandi</span>
                                    break;
                                case PediatriNobetSistemi.Models.Entities.RandevuDurumu.Iptal:
                                    <span class="badge bg-danger">Iptal</span>
                                    break;
                                case PediatriNobetSistemi.Models.Entities.RandevuDurumu.Tamamlandi:
                                    <span class="badge bg-secondary">Tamamlandi</span>
                                    break;
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detay</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Duzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Randevu bulunamadi.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
