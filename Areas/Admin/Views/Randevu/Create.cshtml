@model PediatriNobetSistemi.Models.Entities.Randevu
@{
    ViewData["Title"] = "Yeni Randevu";
}

<h1>Yeni Randevu Ekle</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="AsistanId" class="form-label">Asistan</label>
                    <select asp-for="AsistanId" asp-items="ViewBag.Asistanlar" class="form-select">
                        <option value="">— Asistan sec —</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="OgretimUyesiId" class="form-label">Ogretim Uyesi</label>
                    <select asp-for="OgretimUyesiId" asp-items="ViewBag.OgretimUyeleri" class="form-select">
                        <option value="">— Ogretim uyesi sec —</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Tarih" class="form-label"></label>
                <input asp-for="Tarih" class="form-control" type="date" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="BaslangicSaati" class="form-label"></label>
                    <input asp-for="BaslangicSaati" class="form-control" type="time" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BitisSaati" class="form-label"></label>
                    <input asp-for="BitisSaati" class="form-control" type="time" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Konu" class="form-label">Gorusme Konusu</label>
                <textarea asp-for="Konu" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Durum" class="form-label"></label>
                <select asp-for="Durum" class="form-select">
                    <option value="0">Beklemede</option>
                    <option value="1">Onaylandi</option>
                    <option value="2">Iptal</option>
                    <option value="3">Tamamlandi</option>
                </select>
            </div>

            <button type="submit" class="btn btn-success">Kaydet</button>
            <a asp-action="Index" class="btn btn-secondary">Iptal</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
