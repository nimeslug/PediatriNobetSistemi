@model IEnumerable<PediatriNobetSistemi.Models.Entities.Musaitlik>
@{
    ViewData["Title"] = "Musaitlikler";
    var gunAdlari = new Dictionary<DayOfWeek, string> {
        { DayOfWeek.Monday, "Pazartesi" }, { DayOfWeek.Tuesday, "Sali" },
        { DayOfWeek.Wednesday, "Carsamba" }, { DayOfWeek.Thursday, "Persembe" },
        { DayOfWeek.Friday, "Cuma" }, { DayOfWeek.Saturday, "Cumartesi" }, { DayOfWeek.Sunday, "Pazar" }
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Musaitlikler</h1>
    <a asp-action="Create" class="btn btn-success">+ Yeni Musaitlik Slot</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="card card-body mb-3 bg-light">
    <div class="row align-items-end">
        <div class="col-md-6">
            <label class="form-label">Ogretim Uyesine Gore Filtrele</label>
            <select name="ogretimUyesiId" class="form-select" onchange="this.form.submit()">
                <option value="">— Hepsi —</option>
                @foreach (var o in (dynamic)ViewBag.OgretimUyeleri)
                {
                    var secili = ViewBag.SecilenOgretimUyesi != null && ((int)ViewBag.SecilenOgretimUyesi) == (int)o.Id;
                    <option value="@o.Id" selected="@secili">@o.AdSoyad</option>
                }
            </select>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Ogretim Uyesi</th>
                    <th>Gun</th>
                    <th>Saatler</th>
                    <th>Durum</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.OgretimUyesi?.Unvan @item.OgretimUyesi?.Ad @item.OgretimUyesi?.Soyad</td>
                        <td>@gunAdlari[item.Gun]</td>
                        <td>@item.BaslangicSaati.ToString(@"hh\:mm") - @item.BitisSaati.ToString(@"hh\:mm")</td>
                        <td>
                            @if (item.Aktif) { <span class="badge bg-success">Aktif</span> }
                            else { <span class="badge bg-secondary">Pasif</span> }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Duzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Musaitlik kaydi bulunamadi.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
