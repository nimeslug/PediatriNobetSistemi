@model PediatriNobetSistemi.Models.Entities.Bolum
@{
    ViewData["Title"] = Model.Ad;
}

<a asp-action="Index" class="btn btn-link mb-3">← Tum bolumler</a>

<div class="row">
    <div class="col-md-5">
        @if (!string.IsNullOrEmpty(Model.GorselUrl))
        {
            <img src="@Model.GorselUrl" class="img-fluid rounded shadow" alt="@Model.Ad" />
        }
        else
        {
            <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="height: 300px;">
                <i style="font-size: 5rem;">🏥</i>
            </div>
        }
    </div>
    <div class="col-md-7">
        <h1>@Model.Ad</h1>
        <p class="lead">@Model.Aciklama</p>
        <hr />
        <div class="row text-center mb-3">
            <div class="col-4">
                <div class="card bg-light">
                    <div class="card-body p-3">
                        <div class="text-muted small">Mevcut Hasta</div>
                        <div class="h3 mb-0">@Model.HastaSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-4">
                <div class="card bg-light">
                    <div class="card-body p-3">
                        <div class="text-muted small">Bos Yatak</div>
                        <div class="h3 mb-0 text-success">@Model.BosYatakSayisi</div>
                    </div>
                </div>
            </div>
            <div class="col-4">
                <div class="card bg-light">
                    <div class="card-body p-3">
                        <div class="text-muted small">Toplam Yatak</div>
                        <div class="h3 mb-0">@Model.ToplamYatakSayisi</div>
                    </div>
                </div>
            </div>
        </div>
        @if (Model.SorumluOgretimUyesi != null)
        {
            <div class="card bg-light mb-3">
                <div class="card-body">
                    <small class="text-muted">Sorumlu Ogretim Uyesi</small>
                    <h5 class="mb-0">@Model.SorumluOgretimUyesi.Unvan @Model.SorumluOgretimUyesi.Ad @Model.SorumluOgretimUyesi.Soyad</h5>
                    @if (!string.IsNullOrEmpty(Model.SorumluOgretimUyesi.UzmanlikAlani))
                    {
                        <small class="text-muted">@Model.SorumluOgretimUyesi.UzmanlikAlani</small>
                    }
                </div>
            </div>
        }
    </div>
</div>

@if (Model.Asistanlar.Any())
{
    <hr class="my-4" />
    <h3>Bolumdeki Asistanlar (@Model.Asistanlar.Count)</h3>
    <div class="row mt-3">
        @foreach (var a in Model.Asistanlar)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body d-flex align-items-center">
                        @if (!string.IsNullOrEmpty(a.FotoUrl))
                        {
                            <img src="@a.FotoUrl" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">@a.Ad.FirstOrDefault()</div>
                        }
                        <div>
                            <strong>@a.Ad @a.Soyad</strong><br />
                            <small class="text-muted">@a.AsistanlikYili. yil</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
