@{
    ViewData["Title"] = "Anasayfa";
    Layout = "_Layout";
}

<section class="hero">
    <div class="container">
        <span class="hero-tag">Pediatri Klinigi Yonetim Sistemi</span>
        <h1>Cocuklarin Saglikli Yarinlari Icin<br />Profesyonel Bakim ve Egitim</h1>
        <p class="lead">
            Klinigimizde pediatri asistanlari, ogretim uyeleri ve bolumler arasinda
            koordineli nobet yonetimi, randevu sistemi ve acil durum iletisimi
            tek catida hizmet vermektedir.
        </p>
    </div>
</section>

<section class="container">
    <h2 class="section-title">Hizmetlerimiz</h2>
    <div class="row mt-4">
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Nobet Takvimi</h4>
                <p>Asistanlarimizin gunluk, haftalik ve aylik nobet programlarini takvim formatinda goruntuleyin.</p>
                <a asp-controller="Takvim" asp-action="Index" class="card-link">Takvimi Goruntule</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Bolumlerimiz</h4>
                <p>Cocuk acil, cocuk yogun bakim, cocuk hematoloji ve onkoloji bolumlerinin guncel durumu.</p>
                <a asp-controller="Bolumler" asp-action="Index" class="card-link">Bolumleri Inceleyin</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Acil Durum Bildirimleri</h4>
                <p>Klinige ilskin acil durum haberlerine ve gelismelere hizli erisim.</p>
                <a asp-controller="AcilDurum" asp-action="Index" class="card-link">Bildirimleri Gor</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Asistan Kadrosu</h4>
                <p>Pediatri klinigimizde gorev alan tum asistanlarin profilleri ve iletisim bilgileri.</p>
                <a asp-controller="Asistanlar" asp-action="Index" class="card-link">Asistanlari Tani</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Ogretim Uyeleri</h4>
                <p>Klinigimizde gorev alan ogretim uyeleri, uzmanlik alanlari ve randevu saatleri.</p>
                <a asp-controller="OgretimUyeleri" asp-action="Index" class="card-link">Hocalari Tani</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <h4>Randevu Yonetimi</h4>
                    <p>Ogretim uyelerinden randevu olusturun, mevcut randevularinizi yonetin.</p>
                    <a asp-controller="Randevu" asp-action="Index" class="card-link">Randevularim</a>
                }
                else
                {
                    <h4>Sisteme Giris</h4>
                    <p>Randevu olusturmak ve klinik hizmetlerine erismek icin giris yapin.</p>
                    <a asp-controller="Account" asp-action="Login" class="card-link">Giris Yap</a>
                }
            </div>
        </div>
    </div>
</section>

<section class="container my-5">
    <div class="row text-center">
        <div class="col-md-3 mb-3">
            <div class="stat-box">
                <div class="stat-value">3</div>
                <div class="stat-label">Bolum</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-box">
                <div class="stat-value">15+</div>
                <div class="stat-label">Asistan Hekim</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-box">
                <div class="stat-value">24/7</div>
                <div class="stat-label">Hizmet</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-box">
                <div class="stat-value">100%</div>
                <div class="stat-label">Pediatri Odakli</div>
            </div>
        </div>
    </div>
</section>
