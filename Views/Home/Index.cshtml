@{
    ViewData["Title"] = "Anasayfa";
}

<section class="hero">
    <div class="container">
        <span class="hero-tag">Pediatri Kliniği Yönetim Sistemi</span>
        <h1>Çocukların Sağlıklı Yarınları çin<br />Profesyonel Bakım ve Eğitim</h1>
        <p class="lead">
            Kliniğimizde pediatri asistanları, öğretim üyeleri ve bölümler arasında
            koordineli nöbet yönetimi, randevu sistemi ve acil durum iletişimi
            tek çatı altında hizmet vermektedir.
        </p>
    </div>
</section>

<section class="container">
    <h2 class="section-title">Hizmetlerimiz</h2>
    <div class="row mt-4">
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Nöbet Takvimi</h4>
                <p>Asistanlarımızın günlük, haftalık ve aylık nöbet programlarını takvim formatında görüntüleyin.</p>
                <a asp-controller="Takvim" asp-action="Index" class="card-link">Takvimi Görüntüle</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Bölümlerimiz</h4>
                <p>Çocuk acil, çocuk yoğun bakım, çocuk hematoloji ve onkoloji bölümlerinin güncel durumu.</p>
                <a asp-controller="Bolumler" asp-action="Index" class="card-link">Bölümleri nceleyin</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Acil Durum Bildirimleri</h4>
                <p>Kliniğe ilişkin acil durum haberlerine ve gelişmelere hızlı erişim.</p>
                <a asp-controller="AcilDurum" asp-action="Index" class="card-link">Bildirimleri Gör</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Asistan Kadrosu</h4>
                <p>Pediatri kliniğimizde görev alan tüm asistanların profilleri ve iletişim bilgileri.</p>
                <a asp-controller="Asistanlar" asp-action="Index" class="card-link">Asistanları Tanı</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                <h4>Öğretim Üyeleri</h4>
                <p>Kliniğimizde görev alan öğretim üyeleri, uzmanlık alanları ve randevu saatleri.</p>
                <a asp-controller="OgretimUyeleri" asp-action="Index" class="card-link">Hocaları Tanı</a>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="home-card">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <h4>Randevu Yönetimi</h4>
                    <p>Öğretim üyelerinden randevu oluşturun, mevcut randevularınızı yönetin.</p>
                    <a asp-controller="Randevu" asp-action="Index" class="card-link">Randevularım</a>
                }
                else
                {
                    <h4>Sisteme Giriş</h4>
                    <p>Randevu oluşturmak ve klinik hizmetlerine erişmek için giriş yapın.</p>
                    <a asp-controller="Account" asp-action="Login" class="card-link">Giriş Yap</a>
                }
            </div>
        </div>
    </div>
</section>

<section class="container my-5">
    <div class="row text-center">
        <div class="col-md-3 mb-3">
            <div class="stat-box">
                <div class="stat-value">3</div>
                <div class="stat-label">Bölüm</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-box">
                <div class="stat-value">15+</div>
                <div class="stat-label">Asistan Hekim</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-box">
                <div class="stat-value">24/7</div>
                <div class="stat-label">Hizmet</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-box">
                <div class="stat-value">100%</div>
                <div class="stat-label">Pediatri Odaklı</div>
            </div>
        </div>
    </div>
</section>
